{
    "name": "@agentscope-ai/agentscope",
    "version": "0.0.1",
    "description": "",
    "exports": {
        "./message": {
            "import": "./dist/esm/message/index.js",
            "require": "./dist/cjs/message/index.js",
            "types": "./dist/types/message/index.d.ts"
        },
        "./model": {
            "import": "./dist/esm/model/index.js",
            "require": "./dist/cjs/model/index.js",
            "types": "./dist/types/model/index.d.ts"
        },
        "./tool": {
            "import": "./dist/esm/tool/index.js",
            "require": "./dist/cjs/tool/index.js",
            "types": "./dist/types/tool/index.d.ts"
        },
        "./agent": {
            "import": "./dist/esm/agent/index.js",
            "require": "./dist/cjs/agent/index.js",
            "types": "./dist/types/agent/index.d.ts"
        },
        "./formatter": {
            "import": "./dist/esm/formatter/index.js",
            "require": "./dist/cjs/formatter/index.js",
            "types": "./dist/types/formatter/index.d.ts"
        },
        "./event": {
            "development": "./src/event/index.ts",
            "import": "./dist/esm/event/index.js",
            "require": "./dist/cjs/event/index.js",
            "types": "./dist/types/event/index.d.ts"
        },
        "./module": {
            "import": "./dist/esm/module/index.js",
            "require": "./dist/cjs/module/index.js",
            "types": "./dist/types/module/index.d.ts"
        },
        "./mcp": {
            "import": "./dist/esm/mcp/index.js",
            "require": "./dist/cjs/mcp/index.js",
