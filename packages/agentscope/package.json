        "eslint-plugin-jsdoc": "^61.5.0",
        "eslint-plugin-prettier": "^5.5.4",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "lint-staged": "^16.2.7",
        "prettier": "^3.7.4",
        "ts-jest": "^29.4.6",
        "typedoc": "^0.28.17",
        "typedoc-plugin-markdown": "^4.10.0",
        "typescript": "^5.5.3"
    },
    "dependencies": {
